[
  {
    "id": "recipe_002",
    "name": "辣椒炒肉",
    "coverUrl": "assets/cover.jpg",
    "author": "seikai",
    "createTime": "2026-06-17 10:00:00",
    "difficulty": 2,
    "durationMin": 10,
    "cookedStats": {
      "seikai": 1,
      "echo": 20
    },
    "materials": {
      "ingredients": [
        { "name": "五花肉", "amount": "100g" },
        { "name": "梅花肉", "amount": "200g" },
        { "name": "豆豉", "amount": "8g" },
        { "name": "薄皮辣椒", "amount": "300g" }
      ],
      "seasonings": [
        "大蒜", "小米辣", "生抽", "盐", "老抽", "白糖", "味精", "食用油" 
      ]
    },
    "steps": [
      {
        "id": "s1",
        "type": "prep",
        "content": "五花肉切片，梅花肉切薄片"
      },
	  {
        "id": "s2",
        "type": "prep",
        "content": "加入1g盐（1/3勺），生抽10g（一勺），老抽4g（半勺）腌制梅花肉"
      },
	  {
        "id": "s3",
        "type": "prep",
        "content": "豆豉准备8g，八片蒜切片，四个小米辣切片和大蒜放一起"
      },
	  {
        "id": "s4",
        "type": "prep",
        "content": "薄皮椒滚刀块切小块"
      },
	  {
        "id": "s5",
        "type": "prep",
        "content": "调料汁：一勺生抽，一茶勺白糖，一茶勺味精，半勺老抽"
      },
      {
        "id": "s6",
        "type": "cook",
        "content": "大火烧热锅，喷上一层油"
      },
	  {
        "id": "s7",
        "type": "cook",
        "content": "转为中小火下辣椒，一边按压一边翻炒"
      },
	  {
        "id": "s8",
        "type": "judge",
        "content": "炒热之后加入一茶勺的盐"
      },
	  {
        "id": "s9",
        "type": "judge",
        "content": "辣椒变软，微微虎皮，关火盛出来"
      },
	  {
        "id": "s10",
        "type": "cook",
        "content": "倒入炒菜用量的油，开大火下五花肉片"
      },
	  {
        "id": "s11",
        "type": "judge",
        "content": "炒变色后调为中小火，煸炒出油脂"
      },
	  {
        "id": "s12",
        "type": "judge",
        "content": "五花肉带金黄焦边，下入豆豉炒香，下入小米辣和蒜片，翻炒均匀后转大火"
      },
	  {
        "id": "s13",
        "type": "judge",
        "content": "蒜香味出来之后放入辣椒和腌好的肉，保持大火均匀翻炒"
      },
	  {
        "id": "s14",
        "type": "judge",
        "content": "肉变色之后倒入料汁，一边倒入一边翻炒"
      },
	  {
        "id": "s15",
        "type": "cook",
        "content": "翻匀即可出锅"
      }
    ],
    "tutorials": {
      "type": "video",
      "urls": [
        "assets/tutorial.mp4"
      ]
    },
    "notes": [
      {
        "stepId": "s1",
        "author": "seikai",
        "content": "也可以用300g五花肉肥瘦分离"
      }
    ]
  }
]
